# Environment
APP_ENV=production

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_APP_VERIFICATION_DISABLED_FOR_TESTING=false

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Azure OpenAI
EXPO_PUBLIC_AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
EXPO_PUBLIC_AZURE_OPENAI_RESOURCE_NAME=your_azure_resource_name_here
EXPO_PUBLIC_AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure Speech Service Configuration
EXPO_PUBLIC_AZURE_SPEECH_KEY=your_azure_speech_key_here
EXPO_PUBLIC_AZURE_SPEECH_REGION=eastus2
EXPO_PUBLIC_AZURE_SPEECH_ENDPOINT=https://eastus2.stt.speech.microsoft.com
EXPO_PUBLIC_AZURE_AI_FOUNDRY_ENDPOINT=your_azure_ai_foundry_endpoint_here
EXPO_PUBLIC_AZURE_AI_SERVICES_ENDPOINT=your_azure_ai_services_endpoint_here

# Azure AI Projects Configuration
EXPO_PUBLIC_AZURE_AI_ENDPOINT=your_azure_ai_endpoint_here
EXPO_PUBLIC_AZURE_AI_API_KEY=your_azure_ai_api_key_here
EXPO_PUBLIC_AZURE_AI_AGENT_ID=your_azure_ai_agent_id_here

# OpenAI Configuration (for Voice Features - Whisper & TTS)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Azure Authentication for DefaultAzureCredential
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_TENANT_ID=your_azure_tenant_id_here

# AWS Bedrock Configuration
EXPO_PUBLIC_AWS_BEDROCK_API_KEY_NAME=your_aws_bedrock_api_key_name_here

# AWS Speech Services
EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_AWS_TRANSCRIBE_BUCKET=your-transcribe-bucket-name
EXPO_PUBLIC_AWS_POLLY_OUTPUT_FORMAT=mp3
EXPO_PUBLIC_AWS_POLLY_VOICE_ID=Joanna
EXPO_PUBLIC_AWS_POLLY_ENGINE=neural

# Speech Service Configuration
EXPO_PUBLIC_SPEECH_PROVIDER=azure
EXPO_PUBLIC_SPEECH_FALLBACK_ENABLED=true
EXPO_PUBLIC_AZURE_SPEECH_ENABLED=true
EXPO_PUBLIC_AWS_SPEECH_ENABLED=true

# Azure AI Foundry
EXPO_PUBLIC_AZURE_AI_FOUNDRY_PROJECT_CONNECTION_STRING=your_connection_string_here

# Azure Translator
EXPO_PUBLIC_AZURE_TRANSLATOR_KEY=your_translator_key_here
EXPO_PUBLIC_AZURE_TRANSLATOR_REGION=your_region_here
EXPO_PUBLIC_AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/

# Azure Computer Vision (OCR)
EXPO_PUBLIC_AZURE_COMPUTER_VISION_KEY=your_computer_vision_key_here
EXPO_PUBLIC_AZURE_COMPUTER_VISION_REGION=your_region_here
EXPO_PUBLIC_AZURE_COMPUTER_VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/

# Other Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_ENVIRONMENT=development